{
  "name": "threads",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "fix-node-pty": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true; chmod +x node_modules/node-pty/prebuilds/darwin-x64/spawn-helper 2>/dev/null || true",
    "server": "npm run fix-node-pty && tsx scripts/run-server.ts",
    "server:reload": "touch server-reload.trigger",
    "supervisor:reload": "tsx scripts/reload-supervisor.ts",
    "vite": "vite",
    "dev": "concurrently -k -n api,web -c yellow,cyan \"npm:server\" \"npm:vite\"",
    "reload": "curl -fsS -X POST \"http://127.0.0.1:${PORT:-5224}/__reload\"",
    "build": "npm run lint:complexity && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "lint:complexity": "lizard -w -Eduplicate -C70 -L200 -s nloc src",
    "format": "prettier --write .",
    "postinstall": "npm run fix-node-pty"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.21.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "prettier": "^3.5.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
